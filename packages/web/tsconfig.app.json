{
  "extends": "./tsconfig.json",
  "include": ["./declaration.d.ts", "./src/**/*.ts", "./src/**/*.tsx"],
  "exclude": [
    "./src/**/__tests__/**",
    "./src/**/*.test.ts",
    "./src/**/*.test.tsx",
    "./src/**/*.test-util.ts",
    "./src/**/*.test-util.tsx",
    "./src/**/*.spec.ts",
    "./src/**/*.spec.tsx"
  ],
  "compilerOptions": {
    "noEmit": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@web/*": ["./src/*"],
      "@core/*": ["../core/src/*"],
      "@backend/*": ["../backend/src/*"]
    }
  }
}
