{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noNoninteractiveElementToInteractiveRole": "warn",
        "noNoninteractiveTabindex": "warn",
        "noPositiveTabindex": "warn",
        "noRedundantRoles": "warn",
        "noStaticElementInteractions": "warn",
        "noSvgWithoutTitle": "warn",
        "useAriaPropsForRole": "warn",
        "useAriaPropsSupportedByRole": "warn",
        "useButtonType": "warn",
        "useFocusableInteractive": "warn",
        "useHtmlLang": "warn",
        "useSemanticElements": "warn",
        "useValidAriaRole": "warn"
      },
      "correctness": {
        "noUnreachable": "warn",
        "useExhaustiveDependencies": "warn",
        "useHookAtTopLevel": "warn",
        "useYield": "warn"
      },
      "style": {
        "useImportType": {
          "level": "warn",
          "options": {
            "style": "inlineType"
          }
        }
      },
      "suspicious": {
        "noArrayIndexKey": "warn",
        "noAssignInExpressions": "warn",
        "noConsole": "off",
        "noDoubleEquals": "warn",
        "noDuplicateTestHooks": "warn",
        "noExportsInTest": "warn",
        "useIterableCallbackReturn": "warn"
      },
      "nursery": {
        "useSortedClasses": {
          "level": "warn",
          "options": {
            "attributes": ["className", "class"],
            "functions": ["clsx", "classnames", "cn"]
          }
        }
      }
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              [":PACKAGE:", "!@core/**", "!@web/**", "!@backend/**"],
              ["@*", "!@core/**", "!@web/**", "!@backend/**"],
              ["@core/**", "!@core"],
              ["@web/**", "!@web"],
              ["@backend/**", "!@backend"],
              ":PATH:"
            ]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["packages/web/**/*.ts", "packages/web/**/*.tsx"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": {
              "level": "warn",
              "options": {
                "allow": ["warn", "error"]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "**/__tests__/**",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.js", "**/*.mjs", "**/*.cjs"],
      "linter": {
        "rules": {
          "style": {
            "useImportType": "off"
          }
        }
      }
    }
  ],
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!build",
      "!coverage",
      "!logs",
      "!node_modules",
      "!*.min.js",
      "!bun.lock"
    ]
  }
}
