{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bunx biome format --write . --no-errors-on-unmatched >/dev/null",
            "timeout": 60,
            "statusMessage": "Formatting workspace"
          }
        ]
      }
    ]
  }
}
