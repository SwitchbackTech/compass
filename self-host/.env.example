# Copy this file to .env and replace the generated local defaults before use.

# Compose
COMPOSE_PROJECT_NAME=compass
COMPASS_REF=main

# Local ports
WEB_PORT=9080
PORT=3000

# Runtime
NODE_ENV=production
TZ=Etc/UTC
LOG_LEVEL=info

# Local URLs
FRONTEND_URL=http://localhost:9080
BASEURL=http://localhost:3000/api
CORS=http://localhost:9080,http://localhost:3000

# Compass MongoDB
MONGO_INITDB_ROOT_USERNAME=compass
MONGO_INITDB_ROOT_PASSWORD=change-me-mongo-password-32chars
MONGO_URI=mongodb://compass:change-me-mongo-password-32chars@mongo:27017/prod_calendar?authSource=admin

# SuperTokens Postgres
SUPERTOKENS_POSTGRES_USER=supertokens
SUPERTOKENS_POSTGRES_PASSWORD=change-me-supertokens-postgres-pass-32
SUPERTOKENS_POSTGRES_DB=supertokens

# SuperTokens Core
SUPERTOKENS_URI=http://supertokens:3567
SUPERTOKENS_KEY=change-me-supertokens-key-32chars

# Internal tokens
TOKEN_COMPASS_SYNC=change-me-compass-sync-token-32chars
TOKEN_GCAL_NOTIFICATION=change-me-gcal-notification-token-32chars

# Google OAuth
GOOGLE_CLIENT_ID=compass-self-host-placeholder.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=compass-self-host-placeholder-secret
CHANNEL_EXPIRATION_MIN=10
