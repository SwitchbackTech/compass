# Copy this file to .env and fill in the values marked "generate".
# Generate secrets with: openssl rand -hex 32

# Compose
COMPASS_VERSION=latest

# Local ports
WEB_PORT=9080
PORT=3000

# Runtime
NODE_ENV=production
TZ=Etc/UTC
LOG_LEVEL=info

# Local URLs
FRONTEND_URL=http://localhost:9080
BASEURL=http://localhost:3000/api
CORS=http://localhost:9080,http://localhost:3000
# Optional: public HTTPS URL used only for Google Calendar webhook callbacks.
# Keep BASEURL local if browser traffic should stay on localhost.
# GCAL_WEBHOOK_BASEURL=https://example.trycloudflare.com/api

# Compass MongoDB
MONGO_INITDB_ROOT_USERNAME=compass
MONGO_INITDB_ROOT_PASSWORD=change-me-mongo-password-32chars    # generate
MONGO_REPLICA_SET_KEY=change-me-mongo-replica-set-key-32chars  # generate
MONGO_URI=mongodb://compass:change-me-mongo-password-32chars@mongo:27017/prod_calendar?authSource=admin&replicaSet=rs0

# SuperTokens Postgres
SUPERTOKENS_POSTGRES_USER=supertokens
SUPERTOKENS_POSTGRES_PASSWORD=change-me-supertokens-postgres-pass-32  # generate
SUPERTOKENS_POSTGRES_DB=supertokens

# SuperTokens Core
SUPERTOKENS_URI=http://supertokens:3567
SUPERTOKENS_KEY=change-me-supertokens-key-32chars  # generate

# Internal tokens
TOKEN_COMPASS_SYNC=change-me-compass-sync-token-32chars           # generate
TOKEN_GCAL_NOTIFICATION=change-me-gcal-notification-token-32chars # generate

# Google OAuth (leave placeholders for email/password-only mode)
GOOGLE_CLIENT_ID=compass-self-host-placeholder.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=compass-self-host-placeholder-secret
CHANNEL_EXPIRATION_MIN=10
